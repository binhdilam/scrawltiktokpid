{
  "manifest_version": 3,
  "name": "TikTok PID Extractor",
  "version": "2.1",
  "description": "Lấy Product ID từ video TikTok có gắn sản phẩm",
  "permissions": ["tabs", "scripting", "storage", "notifications", "sidePanel"],
  "host_permissions": ["https://www.tiktok.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_title": "TikTok PID Extractor"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
